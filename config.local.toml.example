# SecondBrain — local overrides (gitignored). Copy of the knobs you'll most likely
# change on your Mac mini. Anything you omit falls back to config.toml defaults.
# Secrets (hf_token, db_passphrase) belong HERE, never in the committed config.toml.
# Env vars also work: SB_CAPTURE__INPUT_DEVICE="MacBook Microphone", HF_TOKEN=...

[capture]
# Name (or substring) from `sb devices`. Empty = system default microphone.
input_device = ""

[consent]
# Raw audio is deleted this many hours after transcription (transcripts are kept).
# 0 = delete immediately, negative = keep forever.
raw_audio_retention_hours = 168    # 7 days

# --- AI features (ON by default here; `deploy/install.sh` sets up their deps) ---
# These need their prerequisites or their queued jobs will fail/no-op:
#   • diarization → a HuggingFace token (gated pyannote models)
#   • LLM / extraction / proactive → a running Ollama with the model pulled
# The chain is: diarization (who-spoke) → extraction (knowledge graph) → proactive
# brief. Extraction only runs on diarized conversations, so a HF token is required
# for the knowledge graph to populate. `install.sh` installs Ollama, pulls the
# model, and prompts for the token. To run capture-only, set enabled = false below.

[diarization]
# Who-spoke + voice profiles. REQUIRES a HuggingFace token: accept the terms on
# pyannote/speaker-diarization-3.1 while logged in, create a read token, and put it
# here (or set HF_TOKEN). Then run `sb speaker setup` / `sb speaker enroll-owner`.
enabled = true
hf_token = ""                     # REQUIRED — install.sh fills this if you provide it

[llm]
# Local LLM for the knowledge graph, Q&A, and the proactive brief. Fully offline
# via Ollama (`ollama serve` + `ollama pull llama3.1:8b-instruct`).
backend = "ollama"
model = "llama3.1:8b-instruct"

[extraction]
enabled = true

[proactive]
enabled = true

# Remote access over Tailscale by binding off-loopback (the server refuses this
# without auth — run `sb auth set-password` first). Or keep 127.0.0.1 + `tailscale
# serve https / 127.0.0.1:8765` and leave this untouched.
# [api]
# host = "100.x.y.z"              # your tailnet IP / MagicDNS name
# [security]
# require_auth = true

# At-rest DB encryption (needs `pip install -e ".[secure]"`). FileVault is the
# recommended baseline; this is defense-in-depth for the structured data.
# [security]
# encrypt_db = true
# db_passphrase = "choose-a-strong-passphrase"   # or SB_SECURITY__DB_PASSPHRASE
